# =====================================================
# Nido — example environment file
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` to git.
# =====================================================

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://postgres:changeme@db:5432/nido
POSTGRES_PASSWORD=changeme

# --- Auth (NextAuth) --------------------------------------------------------
# Public URL where the app is reachable (no trailing slash).
# Local dev:           http://localhost:3001
# Behind nginx subpath: https://your-domain.tld/Nido
NEXTAUTH_URL=http://localhost:3001

# Random 32+ char secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_a_long_random_string

# --- Members (1, 2 or 3 users) ---------------------------------------------
# Each pair AUTH_USER{N}_NAME + AUTH_USER{N}_PASSWORD enables one account.
# Leave both empty to disable that slot.
# NEXT_PUBLIC_USER{N}_NAME must match AUTH_USER{N}_NAME (used for UI display).

AUTH_USER1_NAME=Alice
AUTH_USER1_PASSWORD=replace_me
NEXT_PUBLIC_USER1_NAME=Alice

AUTH_USER2_NAME=Bob
AUTH_USER2_PASSWORD=replace_me
NEXT_PUBLIC_USER2_NAME=Bob

# Optional 3rd member — leave empty if you only want 2 users
AUTH_USER3_NAME=
AUTH_USER3_PASSWORD=
NEXT_PUBLIC_USER3_NAME=

# --- Sub-path deployment (optional) -----------------------------------------
# Leave empty if hosted at the domain root.
# Set to "/Nido" if served at https://your-domain.tld/Nido
NEXT_PUBLIC_BASE_PATH=

# --- Web Push (background notifications) ------------------------------------
# Required so the other phone gets notified even when the screen is off.
# Generate a fresh keypair once with:
#   npx web-push generate-vapid-keys --json
# Then paste the values below. Web Push requires HTTPS (any valid public URL).
# On iPhone the app must be installed via Safari → "Add to Home Screen".
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Used by browsers' push services to identify your app. Any mailto:/https URL works.
VAPID_SUBJECT=mailto:you@example.com

# --- Docker compose port (optional) -----------------------------------------
PORT=3001
